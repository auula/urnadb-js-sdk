{
  "name": "urnadb-js-sdk",
  "version": "1.0.0",
  "type": "module",
  "main": "./src/index.js",
  "types": "./types/index.d.ts",
  "typesVersions": {
    "*": {
      "table": [
        "types/table.d.ts"
      ]
    }
  },
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "import": "./src/index.js"
    },
    "./table": {
      "types": "./types/table.d.ts",
      "import": "./src/table.js"
    }
  },
  "files": [
    "src",
    "types",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "test": "node --test"
  },
  "keywords": [
    "nosql",
    "database",
    "kv",
    "sdk",
    "urnadb"
  ],
  "author": "Leon Ding <ding_ms@outlook.com> (https://leonding.me)",
  "license": "MIT",
  "description": "An ES6 JavaScript SDK for UrnaDB, a document-oriented NoSQL database. Provides APIs for database connections, collections, documents, and data operations."
}
